{
  "name": "qmem",
  "version": "0.1.0",
  "description": "跨会话 AI 记忆三件套（V4.0 三 MCP 正交架构）：QMem 项目记忆（架构/进度/踩坑/决策）+ DomainKG 业务概念图谱（电力调度领域知识）+ codebase-memory 代码事实图谱（函数/调用/表字段）。",
  "author": { "name": "cly" },
  "license": "MIT",
  "skills": "skills",
  "mcpServers": {
    "QMem": {
      "command": "${user_config.python_path}",
      "args": ["-u", "${ZCODE_PLUGIN_ROOT}\\mcp\\qmem\\server.py"],
      "env": {
        "PYTHONUTF8": "1"
      }
    },
    "DomainKG": {
      "command": "${user_config.python_path}",
      "args": ["-u", "${ZCODE_PLUGIN_ROOT}\\mcp\\domain-kg\\server.py"],
      "env": {
        "PYTHONUTF8": "1"
      }
    },
    "codebase-memory": {
      "command": "${ZCODE_PLUGIN_ROOT}\\mcp\\codebase-memory\\codebase-memory-mcp.exe",
      "args": []
    }
  },
  "userConfig": {
    "python_path": {
      "type": "string",
      "default": "C:\\Users\\Administrator\\AppData\\Local\\Programs\\Python\\Python313\\python.exe",
      "description": "Python 3.10+ 解释器绝对路径（需预装 sqlite-vec/onnxruntime/tokenizers/numpy/huggingface-hub）"
    }
  }
}
